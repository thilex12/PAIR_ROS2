<?xml version="1.0" ?>
<robot name="My robot">
    <webots>
        <device reference="gps" type="GPS">
            <ros>
                <topicName>gps</topicName>
                <alwaysOn>true</alwaysOn>
            </ros>
        </device>
        <device reference="ds0" type="DistanceSensor">
            <ros>
                <topicName>left_sensor</topicName>
                <alwaysOn>true</alwaysOn>
            </ros>
        </device>
        <device reference="ds1" type="DistanceSensor">
            <ros>
                <topicName>right_sensor</topicName>
                <alwaysOn>true</alwaysOn>
            </ros>
        </device>
        <plugin type="pair.cbba_agent.CbbaAgent" />
    </webots>
</robot>